# .env.example — Copy to .env on server, NEVER commit .env to git!
# cp .env.example .env

# Database
DB_NAME=hrms
DB_USERNAME=hrms_user
DB_PASSWORD=change_me_strong_password_here

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT — generate with: openssl rand -base64 32
JWT_SECRET=your_base64_encoded_256bit_secret_here

# App
SPRING_PROFILE=prod
SERVER_PORT=8080

# GitHub repo (for pulling Docker images from GHCR)
# Format: your-github-username/hrms-backend
GITHUB_REPO=your-org/hrms-backend

# App version (CI/CD updates this automatically)
APP_VERSION=latest

# CORS — frontend URL(s), comma-separated
CORS_ORIGINS=https://your.domain.kz,http://localhost:3000

# Mail (optional — notifications not yet implemented)
# Leave blank to disable mail health check via MANAGEMENT_HEALTH_MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# Domain (used in CI/CD for deployment URL display)
DOMAIN=your.domain.kz

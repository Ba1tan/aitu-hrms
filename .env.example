# .env.example - Copy to .env on server, NEVER commit .env to git!

# Database
DB_NAME=hrms
DB_USERNAME=hrms_user
DB_PASSWORD=change_me_strong_password_here

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=your_base64_encoded_256bit_secret_here

# App
SPRING_PROFILE=prod
SERVER_PORT=8080

# GitHub (for pulling Docker images)
GITHUB_REPO=your-org/hrms-backend

# App version
APP_VERSION=latest

# Mail (optional, for notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your_app_password

# Domain
DOMAIN=your-domain.kz

meta {
  name: 02 My profile
  type: http
  seq: 2
}

get {
  url: {{gateway}}/api/v1/employees/{{employeeId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

assert {
  res.status: eq 200
}

docs {
  EMPLOYEE_VIEW_OWN — succeeds only when {{employeeId}} matches the JWT's
  employeeId claim, or the caller has EMPLOYEE_VIEW_ALL.
}
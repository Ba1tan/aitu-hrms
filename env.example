# Compose project name — must be unique per environment on the same host
# prod:    COMPOSE_PROJECT_NAME=hrms
# staging: COMPOSE_PROJECT_NAME=hrms-staging
COMPOSE_PROJECT_NAME=hrms

# Host ports
# Production:  nginx handles all traffic on NGINX_PORT, frontend not exposed
#   GATEWAY_PORT=8090  NGINX_PORT=8092  FRONTEND_PORT=   (leave empty)
# Staging: frontend exposed directly, no nginx needed
#   GATEWAY_PORT=8091  NGINX_PORT=      (leave empty)   FRONTEND_PORT=3000
GATEWAY_PORT=8090
NGINX_PORT=8092
FRONTEND_PORT=

# Docker images
GATEWAY_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-gateway:main
USER_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-user-service:main
EMPLOYEE_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-employee-service:main
ATTENDANCE_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-attendance-service:main
LEAVE_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-leave-service:main
PAYROLL_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-payroll-service:main
# Pending services — uncomment once each has a Dockerfile and is published.
#AI_ML_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-ai-ml-service:main
#REPORTING_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-reporting-service:main
#NOTIFICATION_SERVICE_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-notification-service:main
#INTEGRATION_HUB_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-integration-hub:main
FRONTEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-frontend:main

# GitHub Packages auth — only used when pulling published images from ghcr.io.
# hrms-common is built locally in each Dockerfile, so no token is needed for
# `docker compose build`. Token needs read:packages scope to pull images.
GITHUB_ACTOR=ba1tan
GITHUB_TOKEN=yourtoken

# Database
DB_NAME=hrms
DB_USERNAME=hrms_user
DB_PASSWORD=change_me_strong_password

#Redis
REDIS_PASSWORD=change_me_redis_password

#RabbitMQ
RABBITMQ_USER=hrms
RABBITMQ_PASS=change_me_rabbit_password

# JWT — use a different secret per environme
# Must be a Base64-encoded random value that decodes to >= 32 bytes (256 bits).
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32
JWT_ACCESS_EXPIRY=900000       # 15 min
JWT_REFRESH_EXPIRY=604800000   # 7 days

# Mail (password reset) — user-service
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_HEALTH_ENABLED=false

# Spring profile
SPRING_PROFILE=prod

# CORS
CORS_ORIGINS=https://hrms.nursnerv.uk

# Per-service URIs — defaults in docker-compose target compose-network names.
# Override only when a service runs outside the compose network.
# AI/ML service (Python FastAPI — face embeddings, anomaly detection)
AI_ML_SERVICE_URI=http://ai-ml-service:8086
# Reporting service (XLSX/PDF + dashboard JSON aggregation)
REPORTING_SERVICE_URI=http://reporting-service:8087
# Notification service (DB / email / push)
NOTIFICATION_SERVICE_URI=http://notification-service:8088
# Integration hub (1C sync, bank files)
INTEGRATION_HUB_URI=http://integration-hub:8089
# ── Compose project name — must be unique per environment on the same host ────
# prod:    COMPOSE_PROJECT_NAME=hrms
# staging: COMPOSE_PROJECT_NAME=hrms-staging
COMPOSE_PROJECT_NAME=hrms

# ── Host ports ────────────────────────────────────────────────────────────────
# Production:  nginx handles all traffic on NGINX_PORT, frontend not exposed
#   GATEWAY_PORT=8090  NGINX_PORT=8092  FRONTEND_PORT=   (leave empty)
# Staging: frontend exposed directly, no nginx needed
#   GATEWAY_PORT=8091  NGINX_PORT=      (leave empty)   FRONTEND_PORT=3000
GATEWAY_PORT=8090
NGINX_PORT=8092
FRONTEND_PORT=

# ── Docker images ─────────────────────────────────────────────────────────────
MONOLITH_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-monolith:main
GATEWAY_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-gateway:main
FRONTEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-frontend:main

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=hrms
DB_USERNAME=hrms_user
DB_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=hrms
RABBITMQ_PASS=change_me_rabbit_password

# ── JWT — use a different secret per environment! ────────────────────────────
# Must be a Base64-encoded random value that decodes to >= 32 bytes (256 bits).
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32

# ── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILE=prod

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://hrms.nursnerv.uk
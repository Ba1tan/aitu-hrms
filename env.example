# ── Compose project name — must be unique per environment on the same host ────
# prod:    COMPOSE_PROJECT_NAME=hrms
# staging: COMPOSE_PROJECT_NAME=hrms-staging
COMPOSE_PROJECT_NAME=hrms

# ── Gateway host port — must be unique per environment on the same host ───────
# prod:    GATEWAY_PORT=8090
# staging: GATEWAY_PORT=8091
GATEWAY_PORT=8090

# ── Docker images ─────────────────────────────────────────────────────────────
MONOLITH_IMAGE=ghcr.io/your-github-username/hrms-backend/hrms-monolith:main
GATEWAY_IMAGE=ghcr.io/your-github-username/hrms-backend/hrms-gateway:main

# ── Database ─────────────────────────────────────────────────────────────────
DB_NAME=hrms
DB_USERNAME=hrms_user
DB_PASSWORD=change_me_strong_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=hrms
RABBITMQ_PASS=change_me_rabbit_password

# ── JWT — use a different secret per environment! ────────────────────────────
JWT_SECRET=change_me_min_32_chars_random_string_here

# ── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILE=prod

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://hrms.nursnerv.uk
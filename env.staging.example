# ── HRMS Staging Environment ─────────────────────────────────────────────────
# Copy to .env and fill in values:
#   cp env.staging.example .env
#
# Staging topology:
#   gateway exposed on GATEWAY_PORT, frontend on FRONTEND_PORT, no nginx.
#   Run: docker compose -f docker-compose.microservices.yml up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Compose project name — keeps staging containers separate from prod ────────
COMPOSE_PROJECT_NAME=hrms-staging

# ── Host ports ────────────────────────────────────────────────────────────────
# Staging: expose gateway and frontend directly; nginx is not needed.
GATEWAY_PORT=8091
NGINX_PORT=
FRONTEND_PORT=3000

# ── Docker images ─────────────────────────────────────────────────────────────
MONOLITH_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-monolith:develop
GATEWAY_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-gateway:develop
FRONTEND_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/YOUR_REPO/hrms-frontend:develop

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=hrms_staging
DB_USERNAME=hrms_user
DB_PASSWORD=staging_strong_password_here

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=staging_redis_password_here

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_USER=hrms
RABBITMQ_PASS=staging_rabbit_password_here

# ── JWT — use a DIFFERENT secret from production! ─────────────────────────────
# Must be a Base64-encoded random value that decodes to >= 32 bytes (256 bits).
# Generate with: openssl rand -base64 32
JWT_SECRET=change_me_generate_with_openssl_rand_base64_32

# ── Spring profile ────────────────────────────────────────────────────────────
SPRING_PROFILE=prod

# ── CORS — staging frontend URL ───────────────────────────────────────────────
CORS_ORIGINS=http://YOUR_SERVER_IP:3000,http://localhost:5173
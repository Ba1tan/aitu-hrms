# ─── HRMS Staging Environment ───────────────────────────────────────────────
# Copy to .env and fill in values
# cp .env.staging.example .env

# GitHub repo (used for Docker image pull)
# Format: your-github-username/hrms-backend
GITHUB_REPO=your-github-username/hrms-backend

# Database
DB_NAME=hrms_staging
DB_USERNAME=hrms_user
DB_PASSWORD=staging_strong_password_here

# Redis
REDIS_PASSWORD=staging_redis_password_here

# JWT — use a DIFFERENT secret from production!
JWT_SECRET=staging-jwt-secret-change-this-min-32-chars

# CORS — staging frontend URL
CORS_ORIGINS=http://localhost:3000,http://YOUR_SERVER_IP:3000

# ai-ml-service — environment template (Python FastAPI, no application.yml)
#
# Copy to .env when scaffolding the service.

# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8086
LOG_LEVEL=INFO

# ── JWT (validated against the same secret as the Java services) ──────────
JWT_SECRET=change_me_must_match_java_services
JWT_ALGORITHM=HS256

# ── Model storage ─────────────────────────────────────────────────────────
MODEL_DIR=/data/hrms/ai-models
EMBEDDING_DIR=/data/hrms/ai-models/embeddings
# Face recognition (InsightFace buffalo_l)
FACE_MODEL_NAME=buffalo_l
FACE_SIMILARITY_THRESHOLD=0.85
FACE_LIVENESS_THRESHOLD=0.50

# ── Anomaly detection ─────────────────────────────────────────────────────
PAYROLL_ANOMALY_THRESHOLD=0.65
ATTENDANCE_FRAUD_THRESHOLD=0.65

# ── Upstream services (for cross-service feature lookups) ─────────────────
USER_SERVICE_URI=http://localhost:8081
EMPLOYEE_SERVICE_URI=http://localhost:8082
ATTENDANCE_SERVICE_URI=http://localhost:8083
PAYROLL_SERVICE_URI=http://localhost:8085

# ── RabbitMQ (for consuming PayrollJobCompletedEvent → retrain triggers) ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=hrms
RABBITMQ_PASS=hrms_pass

# ── Hardware ──────────────────────────────────────────────────────────────
# Force CPU even when CUDA is available (kiosk machines have no GPU).
USE_CUDA=false
NUM_THREADS=4